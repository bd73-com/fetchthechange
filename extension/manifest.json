{
  "manifest_version": 3,
  "name": "FetchTheChange",
  "description": "Track any element on any web page for changes. Get notified when prices drop, stock updates, or content changes.",
  "version": "1.0.2",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["https://ftc.bd73.com/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://ftc.bd73.com/extension-auth"],
      "js": ["auth-relay.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["picker.js", "picker.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
